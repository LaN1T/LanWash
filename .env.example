# LanWash Environment Configuration
# Copy this file to .env and fill in the values.

# -----------------------------------------------------------------------------
# Database (required for docker-compose)
# -----------------------------------------------------------------------------
POSTGRES_USER=lanwash_user
POSTGRES_PASSWORD=
POSTGRES_DB=lanwash_db
DATABASE_URL=postgresql+asyncpg://lanwash_user:YOUR_PASSWORD@db:5432/lanwash_db

# -----------------------------------------------------------------------------
# Backend
# -----------------------------------------------------------------------------
# Must be at least 43 url-safe characters. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-super-secret-key-min-43-chars-use-secrets-token-urlsafe
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ISSUER=lanwash
JWT_AUDIENCE=lanwash-api

# Strong password for the seeded admin user.
INITIAL_ADMIN_PASSWORD=change_me_to_something_secure

# Comma-separated list of allowed frontend origins.
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# -----------------------------------------------------------------------------
# Redis (required for docker-compose)
# -----------------------------------------------------------------------------
REDIS_PASSWORD=change_me_to_something_secure
# Used by the backend; includes the password set above.
REDIS_URL=redis://:change_me_to_something_secure@redis:6379/0

# -----------------------------------------------------------------------------
# AI providers (optional)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
GROQ_API_KEY=
AI_PROVIDER=groq

# -----------------------------------------------------------------------------
# Telegram bot / Mini App
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_MINI_APP_URL=https://app.lanwash.ru

# -----------------------------------------------------------------------------
# Firebase / FCM / App Check
# -----------------------------------------------------------------------------
FIREBASE_CREDENTIALS_PATH=
FIREBASE_APP_ID=
FCM_ENCRYPTION_KEY=
APP_CHECK_ENFORCED=false

# -----------------------------------------------------------------------------
# Error tracking / monitoring
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
PROMETHEUS_API_TOKEN=change_me_to_something_secure

# -----------------------------------------------------------------------------
# Grafana (change defaults in production!)
# -----------------------------------------------------------------------------
GRAFANA_USER=lanwash_admin
GRAFANA_PASSWORD=change_me_to_something_secure

# -----------------------------------------------------------------------------
# Dev-only (used by db/seed.py in non-production environments)
# -----------------------------------------------------------------------------
DEV_WASHER_PASSWORD=change_me_to_something_secure
