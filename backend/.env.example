# Environment: development | testing | production
ENVIRONMENT=development

# Database configuration (example)
# Development: sqlite+aiosqlite:///./lanwash.db
# Production: postgresql+asyncpg://user:password@localhost:5432/db_name
DATABASE_URL=sqlite+aiosqlite:///./lanwash.db

# Security (set a strong, unique secret key here, min 43 chars).
# NEVER use the example value below in production. Generate a fresh secret with:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=REPLACE_WITH_43_PLUS_RANDOM_URLSAFE_CHARS
ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_ISSUER=lanwash
JWT_AUDIENCE=lanwash-api

# Admin configuration (change default password immediately)
INITIAL_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Dev/test seed passwords (must not be default placeholders)
DEV_WASHER_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Redis URL (required in production)
REDIS_URL=redis://localhost:6379/0

# Redis password (required in production)
REDIS_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# CORS allowed origins (comma-separated, no spaces). DO NOT use "*" in production.
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# Debug mode (true = debug routes enabled, never use in production)
DEBUG=false

# Grafana credentials
GRAFANA_USER=lanwash_admin
GRAFANA_PASSWORD=change_me_to_something_secure

# Firebase Admin SDK credentials (service account)
# Get these from Firebase Console → Project Settings → Service Accounts → Generate new private key
# Then copy values from the downloaded JSON.
# IMPORTANT: Never commit the JSON key file! Use these env vars instead.
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_X509_CERT_URL=

# Optional: separate encryption key for FCM tokens (if not set, derived from JWT_SECRET_KEY)
# FCM_ENCRYPTION_KEY=

# Optional: Firebase App Check enforcement on backend
# Set to 'true' in production to require X-Firebase-AppCheck header on all requests
# Flutter client must include the header when this is enabled
APP_CHECK_ENFORCED=false

# Optional: Sentry DSN for error tracking
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# AI providers
AI_PROVIDER=groq
GEMINI_API_KEY=
GROQ_API_KEY=
