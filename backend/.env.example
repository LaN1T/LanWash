# Database configuration (example)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/db_name

# Security (set a strong, unique secret key here, min 32 chars)
JWT_SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Admin configuration (change default password immediately)
INITIAL_ADMIN_PASSWORD=change_me_to_something_secure

# CORS allowed origins (comma-separated, no spaces). DO NOT use "*" in production.
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# Debug mode (true = debug routes enabled, never use in production)
DEBUG=false

# Firebase Admin SDK credentials (service account)
# Get these from Firebase Console → Project Settings → Service Accounts → Generate new private key
# Then copy values from the downloaded JSON.
# IMPORTANT: Never commit the JSON key file! Use these env vars instead.
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_X509_CERT_URL=
